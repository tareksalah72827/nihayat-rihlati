<script>
const SUPABASE_URL = 'https://wjcbtscphwiknrzjjbse.supabase.co';
const SUPABASE_KEY = 'sb_publishable_qNq-yICSwrVY2KuocFIA5g_tYEXawL3';
const { createClient } = supabase;
const db = createClient(SUPABASE_URL, SUPABASE_KEY);

let allBooklets = [];

async function loadBooklets() {
  const { data, error } = await db.from('booklets').select('*').order('created_at', { ascending: false });
  if (error) { showError('booklets'); return; }
  allBooklets = data || [];
  updateStats();
  populateSubjectFilter();
  renderBooklets(allBooklets);
}

async function loadNews() {
  const { data, error } = await db.from('news').select('*').order('created_at', { ascending: false });
  if (error) { showError('news'); return; }
  renderNews(data || []);
}

function updateStats() {
  document.getElementById('totalBooklets').textContent = allBooklets.length;
  const subjects = new Set(allBooklets.map(b => b.subject));
  document.getElementById('totalSubjects').textContent = subjects.size;
}

function populateSubjectFilter() {
  const subjects = [...new Set(allBooklets.map(b => b.subject))];
  const sel = document.getElementById('filterSubject');
  subjects.forEach(s => {
    const o = document.createElement('option'); o.value = s; o.textContent = s; sel.appendChild(o);
  });
}

function renderBooklets(data) {
  const grid = document.getElementById('bookletsGrid');
  if (!data.length) {
    grid.innerHTML = `<div class="empty-state"><div class="icon">📂</div><p>لا توجد بوكليتات متاحة بعد</p></div>`;
    return;
  }
  const icons = {'الفقه':'⚖️','التوحيد':'☝️','التفسير':'📖','الحديث':'📜','اللغة العربية':'✍️','الرياضيات':'📐','العلوم':'🔬','الأحياء':'🧬','الكيمياء':'⚗️','الفيزياء':'⚡'};
  grid.innerHTML = data.map((b,i) => `
    <div class="booklet-card" style="animation-delay:${i*0.05}s">
      <div class="card-top">
        <div class="card-icon">${icons[b.subject] || '📄'}</div>
        <div class="card-badge">${b.year || '2025'}</div>
      </div>
      <div class="card-subject">${b.subject}</div>
      <div class="card-meta">
        <span>${b.grade}</span>
        <span>${b.type || 'نموذج استرشادي'}</span>
      </div>
      <div class="card-actions">
        <a href="${b.file_url}" download class="btn-download">⬇️ تحميل البوكليت</a>
        <a href="#" class="btn-preview" onclick="previewFile('${b.file_url}','${b.subject}');return false;" title="معاينة">👁️</a>
      </div>
    </div>
  `).join('');
}

function renderNews(data) {
  const grid = document.getElementById('newsGrid');
  document.getElementById('totalNews').textContent = data.length;
  if (!data.length) {
    grid.innerHTML = `<div class="empty-state"><div class="icon">📰</div><p>لا توجد أخبار منشورة بعد</p></div>`;
    return;
  }
  grid.innerHTML = data.map(n => `
    <div class="news-card">
      <div class="news-date">${new Date(n.created_at).toLocaleDateString('ar-EG',{year:'numeric',month:'long',day:'numeric'})}</div>
      <div class="news-title">${n.title}</div>
      <div class="news-content">${n.content}</div>
    </div>
  `).join('');
}

function showError(type) {
  const el = document.getElementById(type === 'booklets' ? 'bookletsGrid' : 'newsGrid');
  el.innerHTML = `<div class="empty-state"><div class="icon">⚠️</div><p>تعذّر تحميل البيانات</p></div>`;
}

function filterBooklets() {
  const subject = document.getElementById('filterSubject').value;
  const grade = document.getElementById('filterGrade').value;
  const year = document.getElementById('filterYear').value;
  const search = document.getElementById('searchInput').value.toLowerCase();
  let filtered = allBooklets.filter(b =>
    (!subject || b.subject === subject) &&
    (!grade || b.grade === grade) &&
    (!year || b.year === year) &&
    (!search || b.subject.toLowerCase().includes(search) || b.grade.toLowerCase().includes(search))
  );
  renderBooklets(filtered);
}

document.getElementById('filterSubject').addEventListener('change', filterBooklets);
document.getElementById('filterGrade').addEventListener('change', filterBooklets);
document.getElementById('filterYear').addEventListener('change', filterBooklets);
document.getElementById('searchInput').addEventListener('input', filterBooklets);

function previewFile(url, title) {
  document.getElementById('modalTitle').textContent = title;
  document.getElementById('modalEmbed').src = url;
  document.getElementById('previewModal').classList.add('open');
}
function closeModal() {
  document.getElementById('previewModal').classList.remove('open');
  document.getElementById('modalEmbed').src = '';
}
document.getElementById('previewModal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

function showToast(msg) {
  const t = document.getElementById('toast'); t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}

// Smooth nav highlight on scroll
const sections = ['booklets','news','tips','developer'];
window.addEventListener('scroll', () => {
  let current = '';
  sections.forEach(id => {
    const el = document.getElementById(id);
    if (el && window.scrollY >= el.offsetTop - 100) current = id;
  });
  document.querySelectorAll('.nav-links a').forEach(a => {
    a.classList.toggle('active', a.getAttribute('href') === '#'+current);
  });
});

loadBooklets();
loadNews();
</script>
